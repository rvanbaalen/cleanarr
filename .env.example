# Radarr — target for movie deletions
RADARR_API_KEY=

# Sonarr — target for episode/season/series deletions
SONARR_API_KEY=

# Shared secret the Jellyfin Webhook plugin must send as the X-Webhook-Secret header.
# Generate one with:  openssl rand -hex 24
WEBHOOK_SECRET=

# true = events are logged but nothing is actually deleted.
# Flip to false once you've verified the first real event looks right.
# The UI toggle on the Dashboard overrides this value at runtime.
DRY_RUN=true
