{
  "name": "cleanarr",
  "version": "0.1.0",
  "description": "Jellyfin → Radarr/Sonarr deletion bridge. Delete a movie or episode in Jellyfin; it's unmonitored and removed from the *arr stack automatically.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/rvanbaalen/cleanarr.git"
  },
  "homepage": "https://github.com/rvanbaalen/cleanarr#readme",
  "bugs": "https://github.com/rvanbaalen/cleanarr/issues",
  "author": "Robin van Baalen",
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:ui": "vite",
    "build:server": "tsc -p tsconfig.server.json",
    "build:ui": "vite build",
    "build": "npm run build:ui && npm run build:server",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.ui.json"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^11.3.0",
    "fastify": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
